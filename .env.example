# ── D-corp KPI Bot - Configuration ──
# Copiez ce fichier en .env et remplissez les valeurs

# Token du bot Telegram (obtenu via @BotFather)
TELEGRAM_TOKEN=VOTRE_TOKEN_ICI

# IDs Telegram autorisés (séparés par des virgules)
# Trouvez votre ID avec @userinfobot sur Telegram
ALLOWED_IDS=123456789,987654321

# Chat ID pour les rapports automatiques
# (peut être un groupe : utilisez un ID négatif)
AUTO_REPORT_CHAT_ID=123456789
